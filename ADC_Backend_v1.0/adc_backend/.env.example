# Database
DATABASE_URL=mysql+aiomysql://adc_user:password@localhost:3306/adc_db

# Security
JWT_SECRET_KEY=change-this-to-a-256-bit-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.netlify.app

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PROFESSIONAL=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# Marketplace provisioning
MARKETPLACE_LOGIN_URL=https://application-due-diligence.netlify.app/login

# Activation email (SMTP)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USERNAME=apikey-or-username
SMTP_PASSWORD=your-password
SMTP_FROM_EMAIL=no-reply@adcsystem.co.za
SMTP_BCC=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# App
ENVIRONMENT=development
APP_NAME=Application Due Diligence Canvas
